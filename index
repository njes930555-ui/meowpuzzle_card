<!doctype html>
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>角色生成測試（Proxy版）</title>
</head>
<body>
  <h2>RPG角色測試（Proxy版）</h2>

  <select id="job">
    <option value="knight">騎士</option>
    <option value="alchemist">煉金術士</option>
    <option value="oracle">占卜師</option>
  </select>

  <input id="dark" type="number" value="1" />

  <button id="btn">送出</button>

  <pre id="result"></pre>

<script>
  // 換成你的 Worker URL
  const API = "https://gas-proxy.njes930555.workers.dev/";

  document.getElementById("btn").addEventListener("click", async () => {
    const job = document.getElementById("job").value;
    const dark = Number(document.getElementById("dark").value || 0);

    document.getElementById("result").textContent = "送出中…";

    try {
      const r = await fetch(API, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ job, dark })
      });
      const txt = await r.text();
      let data;
      try { data = JSON.parse(txt); } catch { data = { raw: txt }; }

      document.getElementById("result").textContent = JSON.stringify(data, null, 2);
    } catch (e) {
      document.getElementById("result").textContent = "失敗：" + e.message;
    }
  });
</script>
</body>
</html>
